---
import type { Lang } from '../i18n/translations';
import { ui } from '../i18n/translations';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  lang: Lang;
  currentPage?: string;
}

const { title, lang, currentPage = '' } = Astro.props;
const t = ui[lang];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/styles/global.css`} />
  <slot name="head" />
</head>
<body>
  <Header lang={lang} currentPage={currentPage} />

  <slot />

  <Footer lang={lang} />

  <slot name="scripts" />
</body>
</html>
