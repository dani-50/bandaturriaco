---
import type { Lang } from '../i18n/translations';
import { ui } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
const nav = t.nav;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-about">
        <h3>{t.footer.aboutTitle}</h3>
        <p>{t.footer.aboutText}</p>
        {lang === 'it' && (
          <div class="footer-sostienici">
            <h3>Sostienici</h3>
            <p>con il tuo <strong>5 per mille</strong> destinandolo al codice fiscale</p>
            <p class="footer-cf">81&nbsp;005&nbsp;030&nbsp;317</p>
          </div>
        )}
      </div>
      <div class="footer-links">
        <h3>{t.footer.navTitle}</h3>
        <ul>
          <li><a href={`${base}/${lang}/novita`}>{nav.novita}</a></li>
          <li><a href={`${base}/${lang}/chisiamo`}>{nav.chisiamo}</a></li>
          <li><a href={`${base}/${lang}/corsi`}>{nav.corsi}</a></li>
          <li><a href={`${base}/${lang}/eventi`}>{nav.eventi}</a></li>
          <li><a href={`${base}/${lang}/storia`}>{nav.storia}</a></li>
          <li><a href={`${base}/${lang}/galleria`}>{nav.galleria}</a></li>
          <li><a href={`${base}/${lang}/contatti`}>{nav.contatti}</a></li>
        </ul>
      </div>
      <div class="footer-social">
        <h3>{t.footer.followTitle}</h3>
        <div class="social-icons">
          <a href="https://www.facebook.com/share/1M4RMWF39N/?mibextid=wwXIfr" class="social-icon" title="Facebook" target="_blank" rel="noopener">f</a>
          <a href="https://www.instagram.com/filarmonicaturriaco1870?igsh=Z3RkcnMzbTg1Y3M2" class="social-icon" title="Instagram" target="_blank" rel="noopener">ig</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      {t.footer.copyright} |
      <a href={`${base}/${lang}/privacy`}>{t.footer.privacy}</a> |
      {t.footer.affil} <a href="https://www.anbimafvg.it" target="_blank" rel="noopener">ANBIMA FVG</a>
    </div>
  </div>
</footer>
