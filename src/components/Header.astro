---
import type { Lang } from '../i18n/translations';
import { ui } from '../i18n/translations';

interface Props {
  lang: Lang;
  currentPage?: string;
}

const { lang, currentPage = '' } = Astro.props;
const t = ui[lang];

const langSwitcherPages: Record<string, string> = {
  'index': 'index',
  'societa': 'societa',
  'banda': 'banda',
  'corsi': 'corsi',
  'eventi': 'eventi',
  'storia': 'storia',
  'galleria': 'galleria',
  'contatti': 'contatti',
};

const switchPage = langSwitcherPages[currentPage] ?? 'index';
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const switchPath = (l: string) => switchPage === 'index' ? `${base}/${l}` : `${base}/${l}/${switchPage}`;
---

<header class="site-header">
  <div class="header-top">
    <span class="header-top-text">{t.tagline.toUpperCase()}</span>
    <div class="lang-switcher">
      <a href={switchPath('it')} class:list={[{ active: lang === 'it' }]}>IT</a>
      <a href={switchPath('en')} class:list={[{ active: lang === 'en' }]}>EN</a>
      <a href={switchPath('de')} class:list={[{ active: lang === 'de' }]}>DE</a>
    </div>
  </div>
  <div class="header-main">
    <a href={`${base}/${lang}`} class="site-logo">
      <div class="logo-icon">
        <img
          src={`${base}/asset/images/logo_senza_scritta_gold_bg.png`}
          alt={t.logoAlt}
        />
      </div>
      <div class="site-title">
        SocietÃ  Filarmonica
        <small>di Turriaco</small>
      </div>
    </a>
    <div class="header-actions">
      <button
        class="nav-toggle"
        aria-label={lang === 'de' ? 'MenÃ¼' : 'Menu'}
        onclick="document.querySelector('.main-nav').classList.toggle('open')"
      >
        â˜°
      </button>
      <nav class="main-nav">
        <ul>
          <li>
            <a
              href={`${base}/${lang}/societa`}
              class:list={[{ active: currentPage === 'societa' }]}
            >{t.nav.societa}</a>
          </li>
          <li>
            <a
              href={`${base}/${lang}/banda`}
              class:list={[{ active: currentPage === 'banda' }]}
            >{t.nav.banda}</a>
          </li>
          <li>
            <a
              href={`${base}/${lang}/corsi`}
              class:list={[{ active: currentPage === 'corsi' }]}
            >{t.nav.corsi}</a>
          </li>
          <li>
            <a
              href={`${base}/${lang}/eventi`}
              class:list={[{ active: currentPage === 'eventi' }]}
            >{t.nav.eventi}</a>
          </li>
          <li>
            <a
              href={`${base}/${lang}/storia`}
              class:list={[{ active: currentPage === 'storia' }]}
            >{t.nav.storia}</a>
          </li>
          <li>
            <a
              href={`${base}/${lang}/galleria`}
              class:list={[{ active: currentPage === 'galleria' }]}
            >{t.nav.galleria}</a>
          </li>
          <li>
            <a
              href={`${base}/${lang}/contatti`}
              class:list={[{ active: currentPage === 'contatti' }]}
            >{t.nav.contatti}</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>
