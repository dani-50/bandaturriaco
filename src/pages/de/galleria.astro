---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Fotogalerie — Società Filarmonica di Turriaco" lang="de" currentPage="galleria">
  <div class="page-header">
    <div class="container">
      <h1>Fotogalerie</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Konzerte und Aufmärsche</h2>
        <p>Momente aus unseren Auftritten</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item">
          <div class="gallery-placeholder">🎺</div>
          <div class="gallery-caption">Weihnachtskonzert 2025</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎵</div>
          <div class="gallery-caption">Dreikönigskonzert 2026</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎶</div>
          <div class="gallery-caption">Frühlingskonzert 2025</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎼</div>
          <div class="gallery-caption">Kirchenpatronprozession</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎺</div>
          <div class="gallery-caption">Musikfest</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🥁</div>
          <div class="gallery-caption">Heilige Cäcilia 2025</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Historisches Archiv</h2>
        <p>Bilder aus der Geschichte der Filarmonica</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">Historisches Archiv — frühes 20. Jahrhundert</div>
        </div>
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">Die Fünfzigerjahre</div>
        </div>
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">Die Siebziger — die goldenen Jahre</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
