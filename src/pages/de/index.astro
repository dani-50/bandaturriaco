---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Società Filarmonica di Turriaco — seit 1870" lang="de" currentPage="index">
  <section class="hero">
    <div class="hero-content">
      <h1>Società Filarmonica di Turriaco</h1>
      <p class="subtitle">Über 150 Jahre Musiktradition im Herzen des Isonzo-Gebiets</p>
      <p class="hero-text">
        Eines der traditionsreichsten Blasorchester des gesamten
        Friaul-Julisch Venetien, Zeuge des Wandels der Isonzo-Gebiete
        und außergewöhnliche Brücke zwischen der mitteleuropäischen Kultur und der italienischen Musiktradition.
      </p>
      <div class="hero-buttons">
        <a href={`${import.meta.env.BASE_URL}/de/societa`} class="btn btn-outline">Der Verein</a>
        <a href={`${import.meta.env.BASE_URL}/de/banda`} class="btn btn-outline">Die Kapelle</a>
        <a href={`${import.meta.env.BASE_URL}/de/corsi`} class="btn btn-outline">Unsere Kurse</a>
        <a href={`${import.meta.env.BASE_URL}/de/eventi`} class="btn btn-outline">Kommende Veranstaltungen</a>
        <a href={`${import.meta.env.BASE_URL}/de/storia`} class="btn btn-outline">Unsere Geschichte</a>
        <a href={`${import.meta.env.BASE_URL}/de/galleria`} class="btn btn-outline">Galerie</a>
        <a href={`${import.meta.env.BASE_URL}/de/contatti`} class="btn btn-outline">Kontakt</a>
      </div>
    </div>
    <div class="decorative">𝄞</div>
  </section>
</BaseLayout>
