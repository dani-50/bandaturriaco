---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Die Kapelle — Società Filarmonica di Turriaco" lang="de" currentPage="banda">
  <div class="page-header">
    <div class="container">
      <h1>Die Kapelle</h1>
    </div>
  </div>

  <section class="section">
    <div class="container prose" style="text-align: center;">
      <div class="section-header">
        <h2>Der Dirigent</h2>
      </div>
      <div style="max-width: 600px; margin: 0 auto;">
        <div style="width: 140px; height: 140px; border-radius: 50%; background: var(--color-bg-alt); border: 3px solid var(--color-secondary); margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; font-size: 48px; color: var(--color-primary);">
          🎼
        </div>
        <h3 style="font-size: 26px; margin-bottom: 8px;">M° Fulvio Dose</h3>
        <p style="color: var(--color-secondary); font-style: italic; margin-bottom: 16px;">Dirigent der Società Filarmonica di Turriaco</p>
        <p>Die Società Filarmonica wird derzeit von Kapellmeister Fulvio Dose geleitet, der das Blasorchester mit Leidenschaft und Kompetenz führt, die Verbindung zur Tradition lebendig hält und gleichzeitig die Innovation im Repertoire fördert.</p>
      </div>
    </div>
  </section>
</BaseLayout>
