---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Musikkurse — Società Filarmonica di Turriaco" lang="de" currentPage="corsi">
  <div class="page-header">
    <div class="container">
      <h1>Musikkurse</h1>
    </div>
  </div>

  <section class="section">
    <div class="container prose" style="text-align: center;">
      <p style="font-size: 19px; max-width: 700px; margin: 0 auto 20px;">
        Um die Kontinuität ihrer Tätigkeit zu gewährleisten und jedem die Möglichkeit zu bieten,
        ein Musikinstrument zu erlernen oder zu vertiefen,
        hat die Società Filarmonica seit Jahren <strong>Musikkurse</strong> eingerichtet.
      </p>
      <p style="max-width: 700px; margin: 0 auto;">
        Die Schüler werden in ihrer Ausbildung von qualifizierten Lehrern begleitet.
        Die Gesellschaft hat zudem eine Zusammenarbeit mit dem <strong>Kindergarten
        und der Grundschule von Turriaco</strong> aufgebaut, um auch den Jüngsten
        den Zugang zur Welt der Musik zu ermöglichen.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Unsere Kurse</h2>
        <p>Von Oktober bis Mai, dem Schulkalender folgend</p>
      </div>
      <div class="courses-grid">
        <div class="course-card">
          <div class="course-icon">🎵</div>
          <h3>Musikalische Früherziehung</h3>
          <p>Einführungskurs für Kinder ab 5 Jahren. Erster Zugang zur Musik durch Spiel, Rhythmus und Gesang. Ideal, um die eigenen musikalischen Fähigkeiten zu entdecken.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎺</div>
          <h3>Blechbläser</h3>
          <p>Einzel- und Gruppenkurse für Trompete, Horn, Posaune, Flügelhorn, Euphonium und Tuba. Für Anfänger und Fortgeschrittene.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎷</div>
          <h3>Holzbläser</h3>
          <p>Kurse für Querflöte, Klarinette, Oboe, Fagott und Saxophon. Einzelunterricht mit Konservatoriumsabsolventen.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🥁</div>
          <h3>Schlagwerk</h3>
          <p>Schlagzeug, Pauken, Xylophon und Schlaginstrumente. Studium der Technik und des Blasmusikrepertoires.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">📖</div>
          <h3>Theorie und Gehörbildung</h3>
          <p>Ergänzungskurs in Musiktheorie, Notenlesen und Gehörbildung für alle Instrumentalschüler.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎶</div>
          <h3>Ensemblespiel</h3>
          <p>Ensemblepraxis und Vorbereitung auf die Eingliederung in die Kapelle. Für Schüler, die ein ausreichendes Niveau auf ihrem Instrument erreicht haben.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Praktische Informationen</h2>
      </div>
      <div class="cards-grid" style="max-width: 900px; margin: 0 auto;">
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <h3 style="color: var(--color-secondary); margin-bottom: 16px;">📅 Zeitraum</h3>
            <p><strong>Oktober – Mai</strong><br />Dem Schulkalender folgend</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <h3 style="color: var(--color-secondary); margin-bottom: 16px;">👥 Teilnehmer</h3>
            <p><strong>Offen für alle</strong><br />Kinder, Jugendliche und Erwachsene, Anfänger und Fortgeschrittene</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <h3 style="color: var(--color-secondary); margin-bottom: 16px;">📍 Veranstaltungsort</h3>
            <p><strong>Vereinsräume</strong><br />Turriaco (GO)</p>
          </div>
        </div>
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <p style="font-size: 18px; margin-bottom: 20px;">Für Informationen und Anmeldungen:</p>
        <a href={`${import.meta.env.BASE_URL}de/contatti`} class="btn btn-primary">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</BaseLayout>
