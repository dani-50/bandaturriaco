---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy — Società Filarmonica di Turriaco" lang="en" currentPage="">
  <div class="page-header">
    <div class="container">
      <h1>Privacy Policy</h1>
    </div>
  </div>

  <section class="section">
    <div class="container" style="max-width: 780px; margin: 0 auto;">
      <p>
        This website does not use profiling cookies and does not employ tools to track
        individual user behaviour.
      </p>
      <p>
        The only data collection occurs on a voluntary basis: if a user chooses to contact
        us by sending an e-mail to <strong>info@bandaturriaco.it</strong>, their e-mail
        address (and any other information included in the message) will be used solely to
        respond to the request and will not be shared with third parties or used for
        marketing purposes.
      </p>
      <p>
        Anonymised and aggregated data relating to the pages visited on this website are
        collected exclusively for the purposes of designing and improving the site. This
        data does not allow the identification of individual users in any way.
      </p>
    </div>
  </section>
</BaseLayout>
