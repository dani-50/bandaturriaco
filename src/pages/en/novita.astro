---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news-en'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const renderedPosts = await Promise.all(
  posts.map(async (post) => ({
    data: post.data,
    Content: (await post.render()).Content,
  }))
);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
}

function isoDate(date: Date): string {
  return date.toISOString().substring(0, 10);
}
---

<BaseLayout title="News — Società Filarmonica di Turriaco" lang="en" currentPage="novita">
  <div class="page-header">
    <div class="container">
      <h1>News</h1>
    </div>
  </div>

  <section class="section">
    <div class="container prose">

      {renderedPosts.map(({ data, Content }) => (
        <article class="news-post">
          <header class="news-post-header">
            <h2 class="news-post-title">{data.title}</h2>
            <time class="news-post-date" datetime={isoDate(data.date)}>
              {formatDate(data.date)}
            </time>
          </header>
          <div class="news-post-body">
            <Content />
            {data.image && (
              <figure class="news-figure">
                <img
                  src={`${base}${data.image}`}
                  alt={data.imageAlt ?? ''}
                  style="max-width: 100%; border-radius: 8px;"
                />
                {data.imageCaption && (
                  <figcaption>{data.imageCaption}</figcaption>
                )}
              </figure>
            )}
          </div>
        </article>
      ))}

    </div>
  </section>
</BaseLayout>

<style>
  .news-post {
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--color-border, #e0e0e0);
  }
  .news-post:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .news-post-header {
    margin-bottom: 1.5rem;
  }
  .news-post-title {
    margin-bottom: 0.35rem;
  }
  .news-post-date {
    display: block;
    font-size: 0.88rem;
    color: var(--color-text-muted, #888);
    font-style: italic;
  }
  .news-figure {
    margin: 2.5rem 0 0;
    text-align: center;
  }
  .news-figure figcaption {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-text-muted, #888);
    text-align: center;
  }
</style>