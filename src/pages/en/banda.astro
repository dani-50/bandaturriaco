---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="The Band — Società Filarmonica di Turriaco" lang="en" currentPage="banda">
  <div class="page-header">
    <div class="container">
      <h1>The Band</h1>
    </div>
  </div>

  <section class="section">
    <div class="container prose" style="text-align: center;">
      <div class="section-header">
        <h2>The Conductor</h2>
      </div>
      <div style="max-width: 600px; margin: 0 auto;">
        <div style="width: 140px; height: 140px; border-radius: 50%; background: var(--color-bg-alt); border: 3px solid var(--color-secondary); margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; font-size: 48px; color: var(--color-primary);">
          🎼
        </div>
        <h3 style="font-size: 26px; margin-bottom: 8px;">M° Fulvio Dose</h3>
        <p style="color: var(--color-secondary); font-style: italic; margin-bottom: 16px;">Conductor of the Società Filarmonica di Turriaco</p>
        <p>The Società Filarmonica is currently directed by Maestro Fulvio Dose, who leads the wind band ensemble with passion and expertise, keeping alive the bond with tradition while promoting innovation in the repertoire.</p>
      </div>
    </div>
  </section>
</BaseLayout>
