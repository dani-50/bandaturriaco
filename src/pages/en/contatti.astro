---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Società Filarmonica di Turriaco" lang="en" currentPage="contatti">
  <div class="page-header">
    <div class="container">
      <h1>Contact</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div>
          <div class="section-header" style="text-align: left;">
            <h2>Write to Us or Visit Us</h2>
            <p>For information about events, courses, and collaborations</p>
          </div>
          <ul class="contact-info-list">
            <li>
              <div class="icon">📍</div>
              <div>
                <h4>Address</h4>
                <p>Società Filarmonica di Turriaco<br />34070 Turriaco (GO)<br />Friuli Venezia Giulia, Italy</p>
              </div>
            </li>
            <li>
              <div class="icon">✉</div>
              <div>
                <h4>Email</h4>
                <p>info@filarmonicaturriaco.it</p>
              </div>
            </li>
            <li>
              <div class="icon">📱</div>
              <div>
                <h4>Phone</h4>
                <p>+39 0481 XXX XXX</p>
              </div>
            </li>
            <li>
              <div class="icon">f</div>
              <div>
                <h4>Facebook</h4>
                <p>Società Filarmonica di Turriaco</p>
              </div>
            </li>
          </ul>
          <div style="margin-top: 32px;">
            <h3 style="font-size: 20px; margin-bottom: 12px;">Board</h3>
            <p><strong>President:</strong> Andrea Baldo</p>
            <p><strong>Conductor:</strong> M° Fulvio Dose</p>
          </div>
          <div style="margin-top: 32px;">
            <h3 style="font-size: 20px; margin-bottom: 12px;">Rehearsals</h3>
            <p>Band rehearsals take place weekly at the social headquarters. For information about days and times, please contact us.</p>
          </div>
        </div>
        <div>
          <div class="map-placeholder">
            <iframe
              src="https://www.google.com/maps?q=Turriaco,+GO&z=13&hl=en&output=embed"
              title="Interactive map of Turriaco"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </div>
          <div style="margin-top: 32px; padding: 24px; background: var(--color-bg-alt); border-radius: 8px; border: 1px solid var(--color-border);">
            <h3 style="font-size: 20px; margin-bottom: 16px; text-align: center;">Affiliations</h3>
            <div style="text-align: center;">
              <p style="font-size: 15px; color: var(--color-text-light); margin-bottom: 12px;">
                The Società Filarmonica di Turriaco is a member of:
              </p>
              <p style="font-weight: 700; color: var(--color-primary);">ANBIMA FVG</p>
              <p style="font-size: 14px; color: var(--color-text-light);">
                Associazione Nazionale Bande Italiane<br />Musicali Autonome — Friuli Venezia Giulia
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
