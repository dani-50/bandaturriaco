---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Gallery — Società Filarmonica di Turriaco" lang="en" currentPage="galleria">
  <div class="page-header">
    <div class="container">
      <h1>Photo Gallery</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Concerts and Parades</h2>
        <p>Moments from our performances</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item">
          <div class="gallery-placeholder">🎺</div>
          <div class="gallery-caption">Christmas Concert 2025</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎵</div>
          <div class="gallery-caption">Epiphany Concert 2026</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎶</div>
          <div class="gallery-caption">Spring Concert 2025</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎼</div>
          <div class="gallery-caption">Patron Saint Parade</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎺</div>
          <div class="gallery-caption">Music Festival</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🥁</div>
          <div class="gallery-caption">Saint Cecilia 2025</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Historical Archive</h2>
        <p>Images from the Filarmonica's history</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">Historical archive — early 20th century</div>
        </div>
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">The Nineteen Fifties</div>
        </div>
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">The Seventies — the golden years</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
