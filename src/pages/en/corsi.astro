---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Our Music Courses — Società Filarmonica di Turriaco" lang="en" currentPage="corsi">
  <div class="page-header">
    <div class="container">
      <h1>Our Music Courses</h1>
    </div>
  </div>

  <section class="section">
    <div class="container prose">
      <p>
        To ensure the continuity of its activities and offer the opportunity — to those who wish — to begin or deepen the study of a musical instrument, the Società Filarmonica established its own <strong>Music School</strong> in 1983.
      </p>
      <p>
        The Society has also long maintained a collaboration with the primary schools of Turriaco and San Pier d'Isonzo&mdash;funded through the <em>Band@Scuola</em> grant from the Friuli Venezia Giulia Region via ANBIMA regionale&mdash;to introduce the youngest children to the world of music.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Courses Offered</h2>
      </div>
      <div class="courses-grid">
        <div class="course-card">
          <div class="course-icon">🎵</div>
          <h3>Music Introduction</h3>
          <p>Introductory course for children from 5 years old. A first approach to music through play, rhythm, and singing. Ideal for discovering one's musical aptitudes.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎺</div>
          <h3>Brass</h3>
          <p>Courses for trumpet, French horn, trombone, flugelhorn, euphonium and tuba.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎷</div>
          <h3>Woodwinds</h3>
          <p>Courses for flute, clarinet, and saxophone. The most popular ones.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🥁</div>
          <h3>Percussion</h3>
          <p>Drums, timpani, xylophone, and percussion instruments. Study of technique and band repertoire.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">📖</div>
          <h3>Theory and Sight-Reading</h3>
          <p>Complementary course in music theory, score reading, and sight-reading for all instrumental students.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎶</div>
          <h3>Ensemble Playing</h3>
          <p>Ensemble practice and preparation for joining the band. For students who have reached a sufficient level on their instrument.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Teachers -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Our Teachers</h2>
        <p>Click on a name to view the curriculum</p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 40px; justify-content: center; margin-top: 16px;">
        <div style="text-align: center; width: 160px;">
          <img src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/asset/images/tondo_valeria.jpg`} alt="Veronica Bortot" style="width: 136px; height: 136px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 10px; border: 2px solid var(--color-secondary);" />
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/curriculum/bortot`} title="Curriculum — Veronica Bortot" style="font-size: 14px; color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; font-family: var(--font-body);">Veronica Bortot</a>
        </div>
        <div style="text-align: center; width: 160px;">
          <img src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/asset/images/tondo_colombo.jpg`} alt="Marco Colombo" style="width: 136px; height: 136px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 10px; border: 2px solid var(--color-secondary);" />
          <a href="#" title="Curriculum — Marco Colombo" style="font-size: 14px; color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; font-family: var(--font-body);">Marco Colombo</a>
        </div>
        <div style="text-align: center; width: 160px;">
          <img src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/asset/images/tondo_diego.jpeg`} alt="Diego Donda" style="width: 136px; height: 136px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 10px; border: 2px solid var(--color-secondary);" />
          <a href="#" title="Curriculum — Diego Donda" style="font-size: 14px; color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; font-family: var(--font-body);">Diego Donda</a>
        </div>
        <div style="text-align: center; width: 160px;">
          <img src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/asset/images/tondo_furlan.jpg`} alt="Daniele Furlan" style="width: 136px; height: 136px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 10px; border: 2px solid var(--color-secondary);" />
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/curriculum/furlan`} title="Curriculum — Daniele Furlan" style="font-size: 14px; color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; font-family: var(--font-body);">Daniele Furlan</a>
        </div>
        <div style="text-align: center; width: 160px;">
          <img src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/asset/images/tondo_stefano.jpg`} alt="Stefano Trentin" style="width: 136px; height: 136px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 10px; border: 2px solid var(--color-secondary);" />
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/curriculum/trentin`} title="Curriculum — Stefano Trentin" style="font-size: 14px; color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; font-family: var(--font-body);">Stefano Trentin</a>
        </div>
        <div style="text-align: center; width: 160px;">
          <img src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/asset/images/tondo_gabriele.png`} alt="Gabriele Zimolo" style="width: 136px; height: 136px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 10px; border: 2px solid var(--color-secondary);" />
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/curriculum/zimolo`} title="Curriculum — Gabriele Zimolo" style="font-size: 14px; color: var(--color-secondary); text-decoration: underline; text-underline-offset: 3px; font-family: var(--font-body);">Gabriele Zimolo</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Practical Information</h2>
      </div>
      <div class="cards-grid" style="max-width: 900px; margin: 0 auto;">
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <h3 style="color: var(--color-secondary); margin-bottom: 16px;">📅 Period</h3>
            <p><strong>October – May</strong><br />Following the school calendar</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <h3 style="color: var(--color-secondary); margin-bottom: 16px;">👥 Participants</h3>
            <p><strong>Open to all</strong><br />Children, teenagers, and adults, beginners and beyond</p>
          </div>
        </div>
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <p style="font-size: 18px; margin-bottom: 20px;">For information and enrolment:</p>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/contatti`} class="btn btn-primary">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
