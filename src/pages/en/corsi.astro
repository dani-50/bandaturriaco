---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Music Courses — Società Filarmonica di Turriaco" lang="en" currentPage="corsi">
  <div class="page-header">
    <div class="container">
      <h1>Music Courses</h1>
    </div>
  </div>

  <section class="section">
    <div class="container prose" style="text-align: center;">
      <p style="font-size: 19px; max-width: 700px; margin: 0 auto 20px;">
        To ensure the continuity of its activities and offer the opportunity
        to those who wish to begin or deepen the study of a musical instrument,
        the Società Filarmonica has for years organised <strong>music courses</strong>.
      </p>
      <p style="max-width: 700px; margin: 0 auto;">
        Students are guided in their preparation by qualified teachers.
        The Society has also established a collaboration with the <strong>Kindergarten
        and Primary School of Turriaco</strong>, to allow even the youngest children to
        approach the world of music.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Our Courses</h2>
        <p>From October to May, following the school calendar</p>
      </div>
      <div class="courses-grid">
        <div class="course-card">
          <div class="course-icon">🎵</div>
          <h3>Music Introduction</h3>
          <p>Introductory course for children from 5 years old. A first approach to music through play, rhythm, and singing. Ideal for discovering one's musical aptitudes.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎺</div>
          <h3>Brass</h3>
          <p>Individual and group courses for trumpet, French horn, trombone, flugelhorn, euphonium, and tuba. For beginners and intermediate level.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎷</div>
          <h3>Woodwinds</h3>
          <p>Courses for flute, clarinet, oboe, bassoon, and saxophone. Individual lessons with conservatory-graduated teachers.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🥁</div>
          <h3>Percussion</h3>
          <p>Drums, timpani, xylophone, and percussion instruments. Study of technique and band repertoire.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">📖</div>
          <h3>Theory and Sight-Reading</h3>
          <p>Complementary course in music theory, score reading, and sight-reading for all instrumental students.</p>
        </div>
        <div class="course-card">
          <div class="course-icon">🎶</div>
          <h3>Ensemble Playing</h3>
          <p>Ensemble practice and preparation for joining the band. For students who have reached a sufficient level on their instrument.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Practical Information</h2>
      </div>
      <div class="cards-grid" style="max-width: 900px; margin: 0 auto;">
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <h3 style="color: var(--color-secondary); margin-bottom: 16px;">📅 Period</h3>
            <p><strong>October – May</strong><br />Following the school calendar</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <h3 style="color: var(--color-secondary); margin-bottom: 16px;">👥 Participants</h3>
            <p><strong>Open to all</strong><br />Children, teenagers, and adults, beginners and beyond</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body" style="text-align: center;">
            <h3 style="color: var(--color-secondary); margin-bottom: 16px;">📍 Venue</h3>
            <p><strong>Society's premises</strong><br />Turriaco (GO)</p>
          </div>
        </div>
      </div>
      <div style="text-align: center; margin-top: 40px;">
        <p style="font-size: 18px; margin-bottom: 20px;">For information and enrolment:</p>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/contatti`} class="btn btn-primary">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
