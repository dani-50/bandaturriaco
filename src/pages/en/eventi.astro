---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Events — Società Filarmonica di Turriaco" lang="en" currentPage="eventi">
  <div class="page-header">
    <div class="container">
      <h1>Events and Concerts</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Upcoming Events</h2>
        <p>The concert and performance calendar</p>
      </div>
      <ul class="event-list">
        <li class="event-item">
          <div class="event-date-box"><span class="day">13</span><span class="month">Jun</span></div>
          <div class="event-info">
            <h3>Charity Concert — "La Melagrana"</h3>
            <div class="event-meta">📍 Turriaco</div>
            <p>Charity concert in support of "La Melagrana", a social cooperative that, through initiatives such as the recently opened "AUTstanding" restaurant and pizzeria in Monfalcone, aims to restore dignity, independence and employment opportunities to people with an autism spectrum diagnosis.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">15</span><span class="month">Jul</span></div>
          <div class="event-info">
            <h3>67th Regional Peach and Local Produce Show</h3>
            <div class="event-meta">📍 Fiumicello Villa Vicentina</div>
            <p>An event held, as tradition dictates, in the village centre and Piazzale dei Tigli, offering food stalls, live music, entertainment and tastings of the area's emblematic fruit.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">1</span><span class="month">Aug</span></div>
          <div class="event-info">
            <h3>81st Villacher Kirchtag <em>(to be confirmed)</em></h3>
            <div class="event-meta">📍 Villach</div>
            <p>Austria's largest traditional folk festival, which transforms the historic centre of Villach into an enormous open-air stage with music, fairground rides and food stalls.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">29</span><span class="month">Aug</span></div>
          <div class="event-info">
            <h3>58th International Folklore Parade</h3>
            <div class="event-meta">📍 Gorizia</div>
            <p>On the occasion of the World Folklore Festival "Castello di Gorizia".</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">20</span><span class="month">Dec</span></div>
          <div class="event-info">
            <h3>Christmas Concert</h3>
            <div class="event-meta">📍 Turriaco</div>
             <p>The traditional concert closing the annual season </p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- Past Events -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Past Events</h2>
        <p>An archive of our past performances</p>
