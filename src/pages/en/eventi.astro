---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Events — Società Filarmonica di Turriaco" lang="en" currentPage="eventi">
  <div class="page-header">
    <div class="container">
      <h1>Events and Concerts</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Upcoming Events</h2>
        <p>The concert and performance calendar</p>
      </div>
      <ul class="event-list">
        <li class="event-item">
          <div class="event-date-box"><span class="day">14</span><span class="month">Jun</span></div>
          <div class="event-info">
            <h3>Spring Concert</h3>
            <div class="event-meta">📍 Piazza Libertà, Turriaco — 8:30 PM</div>
            <p>The traditional open-air spring concert with a programme ranging from classical music to great film soundtracks. Free admission.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">22</span><span class="month">Jun</span></div>
          <div class="event-info">
            <h3>Corpus Domini Procession</h3>
            <div class="event-meta">📍 Parish Church, Turriaco — 10:00 AM</div>
            <p>Musical accompaniment to the Corpus Domini procession through the streets of the village.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">5</span><span class="month">Jul</span></div>
          <div class="event-info">
            <h3>Music Festival — Student Recitals</h3>
            <div class="event-meta">📍 Palamarson, Turriaco — 6:00 PM</div>
            <p>Year-end performance by the Society's music course students. Student recitals followed by the full band concert.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">15</span><span class="month">Aug</span></div>
          <div class="event-info">
            <h3>Ferragosto Concert</h3>
            <div class="event-meta">📍 Villa comunale, Turriaco — 9:00 PM</div>
            <p>Traditional open-air summer musical evening. Repertoire of light music, operetta, and film soundtracks. Free admission.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">12</span><span class="month">Oct</span></div>
          <div class="event-info">
            <h3>Autumn Concert</h3>
            <div class="event-meta">📍 Palamarson, Turriaco — 5:00 PM</div>
            <p>Indoor autumn concert featuring a programme of European band music and original compositions.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">22</span><span class="month">Nov</span></div>
          <div class="event-info">
            <h3>Saint Cecilia — Musicians' Feast</h3>
            <div class="event-meta">📍 Parish Church, Turriaco — 10:30 AM</div>
            <p>Celebration of the patron saint of music with Holy Mass and a dedicated concert.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box"><span class="day">21</span><span class="month">Dec</span></div>
          <div class="event-info">
            <h3>Christmas Concert</h3>
            <div class="event-meta">📍 Palamarson, Turriaco — 5:00 PM</div>
            <p>Christmas concert with a traditional repertoire. Possible collaboration with the "Tita Michelàs" Band of Fiumicello.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Recent Events</h2>
        <p>Past events of the season</p>
      </div>
      <div class="cards-grid">
        <div class="card">
          <div class="card-body">
            <div class="card-date">5 April 2026</div>
            <h3>Easter Procession</h3>
            <p>Musical accompaniment to the Easter procession in Gorizia, in collaboration with other bands of the province.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <div class="card-date">22 March 2026</div>
            <h3>Notes of Peace — Holy Mass</h3>
            <p>Participation in the concert and Mass for Peace with the "Tita Michelàs" Band of Fiumicello.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <div class="card-date">6 January 2026</div>
            <h3>Epiphany Concert</h3>
            <p>Traditional Epiphany concert in collaboration with friends from the Fiumicello Villa Vicentina Band.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <div class="card-date">21 December 2025</div>
            <h3>Christmas Concert 2025</h3>
            <p>The Christmas Concert was held at Turriaco's Palamarson with a programme of Christmas and classical music.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
