---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Società Filarmonica di Turriaco — since 1870" lang="en" currentPage="index">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <h1>Società Filarmonica di Turriaco</h1>
      <p class="subtitle">Over 150 years of musical tradition in the heart of the Isonzo region</p>
      <p class="hero-text">
        One of the wind bands with the richest history in the entire
        Friuli Venezia Giulia region, witness to the transformation of the Isonzo lands
        and an exceptional link between Central European culture and the Italian musical tradition.
      </p>
      <div class="hero-buttons">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/novita`} class="btn btn-outline">News</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/chisiamo`} class="btn btn-outline">About Us</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/corsi`} class="btn btn-outline">Our Courses</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/eventi`} class="btn btn-outline">Upcoming Events</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/storia`} class="btn btn-outline">Our History</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/galleria`} class="btn btn-outline">Gallery</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/en/contatti`} class="btn btn-outline">Contact</a>
      </div>
    </div>
    <div class="decorative">𝄞</div>
  </section>
</BaseLayout>
