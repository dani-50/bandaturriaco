---
// Landing page — language selector
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Società Filarmonica di Turriaco — dal 1870</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lora:ital,wght@0,400;0,600;0,700;1,400&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href={`${base}/styles/global.css`} />
</head>
<body>
  <div class="landing-hero">
    <div class="landing-content">
      <div
        class="year-badge"
        style="display:inline-block;padding:6px 24px;border:2px solid #C9A96E;color:#C9A96E;font-size:14px;letter-spacing:3px;text-transform:uppercase;margin-bottom:36px;border-radius:30px;"
      >
        1870
      </div>
      <h1>Società Filarmonica di Turriaco</h1>
      <div class="lang-cards">
        <a href={`${base}/it/index`} class="lang-card">
          <div class="lang-name">Italiano</div>
          <div class="lang-label">Entra</div>
        </a>
        <a href={`${base}/en/index`} class="lang-card">
          <div class="lang-name">English</div>
          <div class="lang-label">Enter</div>
        </a>
        <a href={`${base}/de/index`} class="lang-card">
          <div class="lang-name">Deutsch</div>
          <div class="lang-label">Eintreten</div>
        </a>
      </div>
    </div>
  </div>
</body>
</html>
