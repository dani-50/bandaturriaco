---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Galleria — Società Filarmonica di Turriaco" lang="it" currentPage="galleria">
  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <h1>Galleria Fotografica</h1>
    </div>
  </div>

  <!-- Galleria Concerti -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Concerti e Sfilate</h2>
        <p>Momenti dalle nostre esibizioni</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item">
          <div class="gallery-placeholder">🎺</div>
          <div class="gallery-caption">Concerto di Natale 2025</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎵</div>
          <div class="gallery-caption">Concerto dell'Epifania 2026</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎶</div>
          <div class="gallery-caption">Concerto di Primavera 2025</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎼</div>
          <div class="gallery-caption">Sfilata Patronale</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🎺</div>
          <div class="gallery-caption">Festa della Musica</div>
        </div>
        <div class="gallery-item">
          <div class="gallery-placeholder">🥁</div>
          <div class="gallery-caption">Santa Cecilia 2025</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Galleria Storica -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Archivio Storico</h2>
        <p>Immagini dalla storia della Filarmonica</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">Archivio storico — inizio Novecento</div>
        </div>
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">Anni Cinquanta</div>
        </div>
        <div class="gallery-item" style="background: linear-gradient(135deg, #3a2a1a 0%, #5a4030 100%);">
          <div class="gallery-placeholder">📷</div>
          <div class="gallery-caption">Anni Settanta — la grande stagione</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
