---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contatti — Società Filarmonica di Turriaco" lang="it" currentPage="contatti">
  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <h1>Contatti</h1>
    </div>
  </div>

  <!-- Contatti -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div>
          <div class="section-header" style="text-align: left;">
            <h2>Scrivi o Vieni a Trovarci</h2>
            <p>Per informazioni su eventi, corsi e collaborazioni</p>
          </div>
          <ul class="contact-info-list">
            <li>
              <div class="icon">📍</div>
              <div>
                <h4>Sede</h4>
                <p>
                  Società Filarmonica di Turriaco<br />
                  p.zza Libertà, 35 <br />
                  34070 Turriaco (GO)<br />
                </p>
              </div>
            </li>
            <li>
              <div class="icon">✉</div>
              <div>
                <h4>Email</h4>
                <p>info@bandaturriaco.it</p>
              </div>
            </li>
          </ul>

          <div style="margin-top: 32px;">
            <h3 style="font-size: 20px; margin-bottom: 12px;">Chi contattare</h3>
            <p><strong>Presidente:</strong> Andrea Baldo</p>
            <p><strong>VicePresidente:</strong> Susanna Bertogna</p> 
            <p><strong>Direttore:</strong> M° Fulvio Dose</p>
          </div>

          <div style="margin-top: 32px;">
            <h3 style="font-size: 20px; margin-bottom: 12px;">Prove</h3>
            <p>Le prove della banda si tengono il giovedì, dalle 20:30 alle 22:30  presso la sede sociale. Consultare sempre la sezione Novità per essere informati su eventuali spostamenti di sede o variazioni d'orario.</p>
          </div>
        </div>

        <div>
          <div class="map-placeholder">
            <iframe
              src="https://www.google.com/maps?q=Turriaco,+GO&z=13&hl=it&output=embed"
              title="Mappa interattiva di Turriaco"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </div>

          <div style="margin-top: 32px; padding: 24px; background: var(--color-bg-alt); border-radius: 8px; border: 1px solid var(--color-border);">
            <h3 style="font-size: 20px; margin-bottom: 16px; text-align: center;">Affiliazioni</h3>
            <div style="text-align: center;">
              <p style="font-size: 15px; color: var(--color-text-light); margin-bottom: 12px;">
                La Società Filarmonica di Turriaco è associata a:
              </p>
              <p style="font-weight: 700; color: var(--color-primary);">
                ANBIMA FVG
              </p>
              <p style="font-size: 14px; color: var(--color-text-light);">
                Associazione Nazionale Bande Italiane<br />Musicali Autonome — Friuli Venezia Giulia
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
