---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Eventi — Società Filarmonica di Turriaco" lang="it" currentPage="eventi">
  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <h1>Eventi e Concerti</h1>
    </div>
  </div>

  <!-- Prossimi Eventi -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Prossimi Appuntamenti</h2>
        <p>Il calendario dei concerti e delle esibizioni</p>
      </div>
      <ul class="event-list">
        <li class="event-item">
          <div class="event-date-box">
            <span class="day">14</span>
            <span class="month">Giu</span>
          </div>
          <div class="event-info">
            <h3>Concerto di Primavera</h3>
            <div class="event-meta">📍 Piazza Libertà, Turriaco — ore 20:30</div>
            <p>Il tradizionale concerto di primavera all'aperto con un programma che spazia dalla musica classica alle colonne sonore dei grandi film. Ingresso libero.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box">
            <span class="day">22</span>
            <span class="month">Giu</span>
          </div>
          <div class="event-info">
            <h3>Processione del Corpus Domini</h3>
            <div class="event-meta">📍 Chiesa Parrocchiale, Turriaco — ore 10:00</div>
            <p>Accompagnamento musicale alla processione del Corpus Domini per le vie del paese.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box">
            <span class="day">5</span>
            <span class="month">Lug</span>
          </div>
          <div class="event-info">
            <h3>Festa della Musica — Saggi degli Allievi</h3>
            <div class="event-meta">📍 Palamarson, Turriaco — ore 18:00</div>
            <p>Esibizione di fine anno dei corsi musicali della Società. Saggi degli allievi seguiti dal gran concerto della banda al completo.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box">
            <span class="day">15</span>
            <span class="month">Ago</span>
          </div>
          <div class="event-info">
            <h3>Concerto del Ferragosto</h3>
            <div class="event-meta">📍 Villa comunale, Turriaco — ore 21:00</div>
            <p>Tradizionale serata musicale estiva all'aperto. Repertorio di musica leggera, operetta e colonne sonore. Ingresso libero.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box">
            <span class="day">12</span>
            <span class="month">Ott</span>
          </div>
          <div class="event-info">
            <h3>Concerto d'Autunno</h3>
            <div class="event-meta">📍 Palamarson, Turriaco — ore 17:00</div>
            <p>Concerto autunnale al chiuso con programma di musica da banda europea e composizioni originali.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box">
            <span class="day">22</span>
            <span class="month">Nov</span>
          </div>
          <div class="event-info">
            <h3>Santa Cecilia — Festa dei Musicisti</h3>
            <div class="event-meta">📍 Chiesa Parrocchiale, Turriaco — ore 10:30</div>
            <p>Celebrazione della patrona della musica con Santa Messa e concerto dedicato.</p>
          </div>
        </li>
        <li class="event-item">
          <div class="event-date-box">
            <span class="day">21</span>
            <span class="month">Dic</span>
          </div>
          <div class="event-info">
            <h3>Concerto di Natale</h3>
            <div class="event-meta">📍 Palamarson, Turriaco — ore 17:00</div>
            <p>Concerto natalizio con repertorio tradizionale. Possibile collaborazione con il Gruppo Bandistico "Tita Michelàs" di Fiumicello.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- Eventi Passati -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>Eventi Recenti</h2>
        <p>Gli appuntamenti passati della stagione</p>
      </div>
      <div class="cards-grid">
        <div class="card">
          <div class="card-body">
            <div class="card-date">5 Aprile 2026</div>
            <h3>Processione di Pasqua</h3>
            <p>Accompagnamento musicale alla processione pasquale a Gorizia, in collaborazione con le altre bande della provincia.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <div class="card-date">22 Marzo 2026</div>
            <h3>Note di Pace — Santa Messa</h3>
            <p>Partecipazione al concerto e Messa per la Pace con il Gruppo Bandistico "Tita Michelàs" di Fiumicello.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <div class="card-date">6 Gennaio 2026</div>
            <h3>Concerto dell'Epifania</h3>
            <p>Tradizionale concerto dell'Epifania con la collaborazione degli amici della Banda di Fiumicello Villa Vicentina.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-body">
            <div class="card-date">21 Dicembre 2025</div>
            <h3>Concerto di Natale 2025</h3>
            <p>Presso il Palamarson di Turriaco si è tenuto il Concerto di Natale con un programma di musiche natalizie e classiche.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
