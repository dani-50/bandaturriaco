---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Società Filarmonica di Turriaco — dal 1870" lang="it" currentPage="index">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <h1>Società Filarmonica di Turriaco</h1>
      <p class="subtitle">Oltre 150 anni di tradizione musicale nel cuore dell'Isontino</p>
      <p class="hero-text">
        Uno dei complessi bandistici più ricchi di storia dell'intero
        Friuli&nbsp;Venezia&nbsp;Giulia, testimone del processo di trasformazione delle terre isontine
        e tramite d'eccezione fra la cultura mitteleuropea e la tradizione musicale italiana.
      </p>
      <div class="hero-buttons">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/it/novita`} class="btn btn-outline">Novità</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/it/chisiamo`} class="btn btn-outline">Chi Siamo</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/it/corsi`} class="btn btn-outline">I Nostri Corsi</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/it/eventi`} class="btn btn-outline">Prossimi Eventi</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/it/storia`} class="btn btn-outline">La Nostra Storia</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/it/galleria`} class="btn btn-outline">Galleria</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/it/contatti`} class="btn btn-outline">Contatti</a>
      </div>
    </div>
    <div class="decorative">𝄞</div>
  </section>
</BaseLayout>
