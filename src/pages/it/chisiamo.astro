<style>
  .intro-quote {
    font-size: 1.15rem;
    text-align: center;
    max-width: 780px;
    margin: 0 auto 2rem;
    line-height: 1.7;
    color: var(--color-primary, #4a3000);
  }
  .banda-photo {
    margin: 0 auto 0;
    text-align: center;
  }
  .banda-photo img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    display: block;
  }
  .banda-photo figcaption {
    margin-top: 12px;
    font-size: 14px;
    font-style: italic;
    color: var(--color-text-light, #888);
  }
  .curriculum-link {
    display: inline-block;
    margin-top: 8px;
    color: var(--color-secondary, #8b6f47);
    font-weight: 600;
    text-decoration: none;
  }
  .curriculum-link:hover {
    text-decoration: underline;
  }
    border: 2px dashed var(--color-border, #ccc);
    border-radius: 8px;
    padding: 3rem 1rem;
    text-align: center;
    color: var(--color-text-muted, #999);
    font-style: italic;
    margin: 2.5rem 0;
  }
  .board-list {
    list-style: none;
    padding: 0;
    max-width: 480px;
    margin: 0 auto;
  }
  .board-list li {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--color-border, #e8e8e8);
    font-size: 1rem;
  }
  .board-list li:last-child { border-bottom: none; }
  .members-table {
    width: 100%;
    max-width: 540px;
    margin: 0 auto;
    border-collapse: collapse;
    font-size: 0.97rem;
  }
  .members-table td {
    padding: 0.35rem 1rem 0.35rem 0;
    border-bottom: 1px solid var(--color-border, #eee);
    vertical-align: top;
  }
  .members-table td:first-child { font-weight: 500; min-width: 200px; }
  .members-table td:last-child { color: var(--color-secondary, #7a5c00); font-style: italic; }
  .members-table tr:last-child td { border-bottom: none; }
</style>
