---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="La Banda — Società Filarmonica di Turriaco" lang="it" currentPage="banda">
  <!-- Page Header -->
  <div class="page-header">
    <div class="container">
      <h1>La Banda</h1>
    </div>
  </div>

  <!-- Il Direttore -->
  <section class="section">
    <div class="container prose" style="text-align: center;">
      <div class="section-header">
        <h2>Il Direttore</h2>
      </div>
      <div style="max-width: 600px; margin: 0 auto;">
        <div style="width: 140px; height: 140px; border-radius: 50%; background: var(--color-bg-alt); border: 3px solid var(--color-secondary); margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; font-size: 48px; color: var(--color-primary);">
          🎼
        </div>
        <h3 style="font-size: 26px; margin-bottom: 8px;">M° Fulvio Dose</h3>
        <p style="color: var(--color-secondary); font-style: italic; margin-bottom: 16px;">Direttore della Società Filarmonica di Turriaco</p>
        <p>La Società Filarmonica è attualmente diretta dal Maestro Fulvio Dose, che guida il complesso bandistico con passione e competenza, mantenendo vivo il legame con la tradizione e promuovendo al contempo l'innovazione nel repertorio.</p>
      </div>
    </div>
  </section>
</BaseLayout>
